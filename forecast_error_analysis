   "source": [
    "import requests\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('dark_background')\n",
    "\n",
    "# Fetch Actual Wind Generation (Jan 2024)\n",
    "print(\"Fetching actuals...\")\n",
    "actuals_res = requests.get(\n",
    "    \"https://data.elexon.co.uk/bmrs/api/v1/datasets/FUELHH/stream\",\n",
    "    params={\n",
    "        \"settlementDateFrom\": \"2024-01-01\",\n",
    "        \"settlementDateTo\": \"2024-01-31\",\n",
    "        \"fuelType\": \"WIND\"\n",
    "    }\n",
    ")\n",
    "actuals_data = actuals_res.json()\n",
    "df_actual = pd.DataFrame(actuals_data)\n",
    "df_actual = df_actual[df_actual['fuelType'] == 'WIND'][['startTime', 'generation']]\n",
    "df_actual['startTime'] = pd.to_datetime(df_actual['startTime'])\n",
    "df_actual.rename(columns={'generation': 'actual'}, inplace=True)\n",
    "df_actual = df_actual.drop_duplicates(subset='startTime').sort_values('startTime')\n",
    "print(f\"Actuals: {len(df_actual)} records\")\n",
    "\n",
    "# Fetch Forecast Data (Jan 2024)\n",
    "print(\"Fetching forecasts...\")\n",
    "forecast_res = requests.get(\n",
    "    \"https://data.elexon.co.uk/bmrs/api/v1/datasets/WINDFOR/stream\",\n",
    "    params={\"from\": \"2024-01-01\", \"to\": \"2024-01-31\"}\n",
    ")\n",
    "forecast_data = forecast_res.json()\n",
    "df_forecast = pd.DataFrame(forecast_data)[['startTime', 'publishTime', 'generation']]\n",
    "df_forecast['startTime'] = pd.to_datetime(df_forecast['startTime'])\n",
    "df_forecast['publishTime'] = pd.to_datetime(df_forecast['publishTime'])\n",
    "df_forecast.rename(columns={'generation': 'forecast'}, inplace=True)\n",
    "\n",
    "# Calculate horizon in hours\n",
    "df_forecast['horizon_hrs'] = (\n",
    "    df_forecast['startTime'] - df_forecast['publishTime']\n",
    ").dt.total_seconds() / 3600\n",
    "\n",
    "# Keep only 0-48 hr horizon as per spec\n",
    "df_forecast = df_forecast[\n",
    "    (df_forecast['horizon_hrs'] >= 0) & \n",
    "    (df_forecast['horizon_hrs'] <= 48)\n",
    "]\n",
    "print(f\"Forecasts: {len(df_forecast)} records\")\n",
    "print(\"\\nSample actuals:\")\n",
    "print(df_actual.head(3))\n",
    "print(\"\\nSample forecasts:\")\n",
    "print(df_forecast.head(3))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5935b5d0-7555-43cd-9c5e-ebb43c75b3cb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# For each target time, pick the latest forecast \n",
    "# published at least 4 hours before (default horizon)\n",
    "HORIZON = 4\n",
    "\n",
    "def get_latest_forecast(group, horizon_hrs):\n",
    "    valid = group[group['horizon_hrs'] >= horizon_hrs]\n",
    "    if valid.empty:\n",
    "        return None\n",
    "    return valid.loc[valid['publishTime'].idxmax(), 'forecast']\n",
    "\n",
    "# Apply horizon filter and get one forecast per startTime\n",
    "df_merged_list = []\n",
    "for start_time, group in df_forecast.groupby('startTime'):\n",
    "    forecast_val = get_latest_forecast(group, HORIZON)\n",
    "    if forecast_val is not None:\n",
    "        df_merged_list.append({\n",
    "            'startTime': start_time,\n",
    "            'forecast': forecast_val\n",
    "        })\n",
    "\n",
    "df_filtered_forecast = pd.DataFrame(df_merged_list)\n",
    "\n",
    "# Merge with actuals\n",
    "df = pd.merge(df_actual, df_filtered_forecast, on='startTime', how='inner')\n",
    "df['error'] = df['forecast'] - df['actual']\n",
    "df['abs_error'] = df['error'].abs()\n",
    "df['pct_error'] = (df['abs_error'] / df['actual'].replace(0, np.nan)) * 100\n",
    "\n",
    "print(f\"Merged records: {len(df)}\")\n",
    "print(df[['startTime', 'actual', 'forecast', 'error', 'abs_error']].head(5))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8bef0b3b-3661-4876-9fee-8a40f8f24b96",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\" * 45)\n",
    "print(\"      FORECAST ERROR STATISTICS (MW)\")\n",
    "print(\"=\" * 45)\n",
    "print(f\"  MAE   (Mean Abs Error)   : {df['abs_error'].mean():.1f} MW\")\n",
    "print(f\"  RMSE                     : {np.sqrt((df['error']**2).mean()):.1f} MW\")\n",
    "print(f\"  Median Abs Error         : {df['abs_error'].median():.1f} MW\")\n",
    "print(f\"  P90 Error                : {df['abs_error'].quantile(0.90):.1f} MW\")\n",
    "print(f\"  P99 Error                : {df['abs_error'].quantile(0.99):.1f} MW\")\n",
    "print(f\"  Max Error                : {df['abs_error'].max():.1f} MW\")\n",
    "print(f\"  Mean % Error             : {df['pct_error'].mean():.1f}%\")\n",
    "print(\"=\" * 45)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "35fbee66-f35f-493a-b8fd-001314c79a13",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get error at different horizon buckets\n",
    "horizon_buckets = list(range(0, 49, 4))  # 0, 4, 8, ..., 48\n",
    "horizon_errors = []\n",
    "\n",
    "for h in horizon_buckets:\n",
    "    bucket_list = []\n",
    "    for start_time, group in df_forecast.groupby('startTime'):\n",
    "        forecast_val = get_latest_forecast(group, h)\n",
    "        if forecast_val is not None:\n",
    "            bucket_list.append({\n",
    "                'startTime': start_time,\n",
    "                'forecast': forecast_val\n",
    "            })\n",
    "    \n",
    "    if not bucket_list:\n",
    "        continue\n",
    "        \n",
    "    df_bucket = pd.DataFrame(bucket_list)\n",
    "    df_h = pd.merge(df_actual, df_bucket, on='startTime', how='inner')\n",
    "    if len(df_h) > 0:\n",
    "        mae = (df_h['forecast'] - df_h['actual']).abs().mean()\n",
    "        horizon_errors.append({'horizon': h, 'mae': mae, 'count': len(df_h)})\n",
    "\n",
    "df_horizon = pd.DataFrame(horizon_errors)\n",
    "\n",
    "# Plot\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "ax.plot(df_horizon['horizon'], df_horizon['mae'], \n",
    "        color='#34D399', marker='o', linewidth=2.5, markersize=6)\n",
    "ax.fill_between(df_horizon['horizon'], df_horizon['mae'], alpha=0.15, color='#34D399')\n",
    "ax.set_xlabel('Forecast Horizon (hours)', fontsize=12)\n",
    "ax.set_ylabel('MAE (MW)', fontsize=12)\n",
    "ax.set_title('Forecast Error vs Horizon — Longer horizon = higher error', fontsize=13)\n",
    "ax.grid(True, alpha=0.2)\n",
    "plt.tight_layout()\n",
    "plt.savefig('error_vs_horizon.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved: error_vs_horizon.png\")"
   ]
  },
